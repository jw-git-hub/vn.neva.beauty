<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <script>document.documentElement.classList.add('js')</script>
  <title>{{ page.seo_title }}</title>
  <meta name="description" content="{{ page.seo_desc }}">
  <meta name="robots" content="{{ 'noindex, follow' if page.noindex else 'index, follow' }}">
  <link rel="canonical" href="{{ site.base_url }}{{ page.url }}">
  <link rel="alternate" hreflang="ru" href="{{ site.base_url }}{{ page.url }}">
  <link rel="alternate" hreflang="x-default" href="{{ site.base_url }}{{ page.url }}">
  <meta property="og:type" content="{{ page.og_type | default('website') }}">
  <meta property="og:site_name" content="{{ site.brand }}">
  <meta property="og:locale" content="ru_RU">
  <meta property="og:title" content="{{ page.seo_title }}">
  <meta property="og:description" content="{{ page.seo_desc }}">
  <meta property="og:url" content="{{ site.base_url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.base_url }}{{ page.og_image | default('/assets/img/hero.jpg') }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page.seo_title }}">
  <meta name="twitter:description" content="{{ page.seo_desc }}">
  <meta name="twitter:image" content="{{ site.base_url }}{{ page.og_image | default('/assets/img/hero.jpg') }}">
  {% if page.schema_json %}<script type="application/ld+json">{{ page.schema_json }}</script>{% endif %}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant:wght@500;600&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/tokens.css">
  <link rel="stylesheet" href="/assets/css/base.css">
  <link rel="stylesheet" href="/assets/css/components.css">
  <link rel="stylesheet" href="/assets/css/aurora.css">
  <link rel="stylesheet" href="/assets/css/reveal.css">
  {% block extra_css %}{% endblock %}
</head>
<body>
  {% include 'partials/aurora.html.j2' %}
  {% include 'partials/header.html.j2' %}
  {# drawer/overlay — на уровне body, вне backdrop-filter хедера,
     иначе их position:fixed считается от коробки хедера, а не вьюпорта #}
  {% include 'partials/drawer.html.j2' %}
  <main id="main">{% block content %}{% endblock %}</main>
  {% include 'partials/footer.html.j2' %}
  <script type="module" src="/assets/js/nav.js"></script>
  <script type="module" src="/assets/js/reveal.js"></script>
  <script type="module" src="/assets/js/aurora.js"></script>
  {% block extra_js %}{% endblock %}
</body>
</html>
