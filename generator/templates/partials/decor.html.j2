{#-
  Фоновый декор: слой «световой пыли» (bokeh).
  Единый источник разметки частиц для всех страниц.
  variant выбирает раскладку: 'soft' (секции на --bg), 'accent' (секции на --surface).
  Каждая частица несёт data-depth для параллакса и CSS-переменные для вида/дрейфа.
-#}
{%- set layouts = {
  'soft': [
    {'x':'-5%','y':'6%','size':'clamp(150px,21vw,300px)','tint':'var(--rose-soft)','op':'.26','blur':'10px','dur':'24s','delay':'0s','dx':'20px','dy':'-14px','depth':'0.05'},
    {'x':'90%','y':'2%','size':'clamp(100px,14vw,210px)','tint':'var(--taupe)','op':'.18','blur':'12px','dur':'28s','delay':'-7s','dx':'-16px','dy':'18px','depth':'0.10'},
    {'x':'74%','y':'66%','size':'clamp(170px,23vw,340px)','tint':'var(--rose-soft)','op':'.20','blur':'14px','dur':'32s','delay':'-13s','dx':'-22px','dy':'-18px','depth':'0.04'},
    {'x':'8%','y':'80%','size':'clamp(90px,12vw,170px)','tint':'#E7C0B4','op':'.16','blur':'10px','dur':'26s','delay':'-4s','dx':'14px','dy':'16px','depth':'0.08'}
  ],
  'accent': [
    {'x':'-6%','y':'12%','size':'clamp(160px,22vw,320px)','tint':'#E7C0B4','op':'.24','blur':'12px','dur':'25s','delay':'0s','dx':'22px','dy':'-12px','depth':'0.05'},
    {'x':'92%','y':'8%','size':'clamp(120px,16vw,240px)','tint':'var(--rose-soft)','op':'.22','blur':'12px','dur':'29s','delay':'-8s','dx':'-18px','dy':'16px','depth':'0.09'},
    {'x':'4%','y':'74%','size':'clamp(130px,18vw,260px)','tint':'var(--taupe)','op':'.16','blur':'14px','dur':'31s','delay':'-5s','dx':'16px','dy':'-16px','depth':'0.07'},
    {'x':'80%','y':'78%','size':'clamp(150px,20vw,300px)','tint':'var(--rose-soft)','op':'.20','blur':'14px','dur':'34s','delay':'-15s','dx':'-20px','dy':'-14px','depth':'0.04'},
    {'x':'48%','y':'-8%','size':'clamp(110px,15vw,220px)','tint':'#E7C0B4','op':'.14','blur':'12px','dur':'27s','delay':'-11s','dx':'12px','dy':'18px','depth':'0.06'}
  ]
} -%}
{%- macro decor(variant='soft') -%}
<div class="decor decor--{{ variant }}" aria-hidden="true">
{%- for d in layouts.get(variant, layouts['soft']) %}
  <span class="decor__dot" data-depth="{{ d.depth }}" style="--x:{{ d.x }};--y:{{ d.y }};--size:{{ d.size }};--tint:{{ d.tint }};--op:{{ d.op }};--blur:{{ d.blur }};--dur:{{ d.dur }};--delay:{{ d.delay }};--dx:{{ d.dx }};--dy:{{ d.dy }}"></span>
{%- endfor %}
</div>
{%- endmacro -%}
